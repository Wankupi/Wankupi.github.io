{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "composite": true,
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "./*"
            ],
            "#posts-data": [
                "./data/posts.data.ts"
            ],
        },
    },
    "include": [
        "**/*.ts",
        "**/*.vue",
        "main.ts",
    ],
    "exclude": [
        "node_modules",
        "docs/.vuepress/.cache",
        "docs/.vuepress/.temp",
        "docs/.vuepress/dist"
    ],
}